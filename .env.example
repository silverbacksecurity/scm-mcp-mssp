# ──────────────────────────────────────────────────────────────────────────────
# SCM MCP MSSP — environment variable reference
# Copy to .env and fill in values. Never commit .env or .secrets.toml.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
SCM_MCP_LOG_LEVEL=INFO
SCM_MCP_LOG_JSON=true

# ── HTTP / SSE transport (Copilot Studio) ─────────────────────────────────────
# Generate a key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SCM_MCP_HTTP_PORT=8080
SCM_MCP_HTTP_AUTH_MODE=apikey            # apikey | entra | none
SCM_MCP_HTTP_API_KEY=your-api-key-here
SCM_MCP_HTTP_ALLOWED_ORIGINS=*

# Entra ID auth (set SCM_MCP_HTTP_AUTH_MODE=entra to use)
SCM_MCP_HTTP_ENTRA_TENANT=your-entra-tenant-id
SCM_MCP_HTTP_ENTRA_AUDIENCE=your-app-registration-client-id

# ── MSSP mode ─────────────────────────────────────────────────────────────────
# Set to true to enable multi-tenant mode (credentials loaded from settings.toml)
SCM_MCP_MSSP_MODE=false

# ── Default / single-tenant SCM credentials ───────────────────────────────────
# Obtain from PAN Customer Support Portal → Strata Cloud Manager → API Keys
SCM_MCP_SCM_TENANT_ID=your-tsg-id
SCM_MCP_SCM_CLIENT_ID=your-client-id@iam.panserviceaccount.com
SCM_MCP_SCM_CLIENT_SECRET=your-client-secret
SCM_MCP_SCM_DEFAULT_FOLDER=Shared
