# ──────────────────────────────────────────────────────────────────────────────
# .secrets.toml.example — copy to .secrets.toml and fill in secrets
# NEVER commit .secrets.toml — it is in .gitignore
# ──────────────────────────────────────────────────────────────────────────────

[default]
scm_client_secret = "your-default-client-secret"

# Per-tenant secrets (mirrors the [tenants.*] blocks in settings.toml)
# [tenants.customer-a]
# client_secret = "customer-a-secret"
#
# [tenants.customer-b]
# client_secret = "customer-b-secret"
